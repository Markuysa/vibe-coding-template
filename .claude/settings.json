      "Read(~/.kube/config)",
      "Read(node_modules/**)",
      "Read(vendor/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(target/**)",
      "Read(coverage/**)",
      "Read(.git/objects/**)",
      "Read(package-lock.json)",
      "Read(pnpm-lock.yaml)",
